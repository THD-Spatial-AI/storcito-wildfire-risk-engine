# Public HAProxy port; the four API containers listen internally on 8085.
STORCITO_HOST=0.0.0.0
STORCITO_PORT=8085
STORCITO_HAPROXY_STATS_PORT=8406
STORCITO_POSTGRES_PORT=5435

# PostGIS credentials (shared by postgis, storcito and geotools).
POSTGRES_DB=gis
POSTGRES_USER=gis
POSTGRES_PASSWORD=gis

# Host connection for scripts/load_localhost.py (compose overrides inside Docker).
PGHOST=127.0.0.1
PGPORT=5435
PGDATABASE=gis
PGUSER=gis
PGPASSWORD=gis

# Optional external URL for download links; empty = infer from request.
PUBLIC_BASE_URL=

# Sentinel-2: dataspace.copernicus.eu -> Sentinel Hub -> OAuth clients -> Create.
SH_CLIENT_ID=
SH_CLIENT_SECRET=

# CLC land cover: service-key JSON from land.copernicus.eu profile API tokens.
CLMS_SERVICE_KEY_JSON=secrets/land-copernicus.json
CLMS_ACCESS_TOKEN=

# ASTER GDEM 30 m elevation: NASA Earthdata login (urs.earthdata.nasa.gov).
EARTHDATA_USERNAME=
EARTHDATA_PASSWORD=
EARTHACCESS_STRATEGY=environment

# Landsat LST: USGS EROS username + access token (ers.usgs.gov -> Profile -> Access Tokens).
EROS_USERNAME=
EROS_TOKEN=

# Fire history hotspots: NASA FIRMS key from firms.modaps.eosdis.nasa.gov/api/map_key.
FIRMS_MAP_KEY=

